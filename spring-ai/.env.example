# Spring AI 应用环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不应提交到 Git 仓库

# ========================================
# AI API 配置
# ========================================
AI_API_KEY=your-dashscope-api-key-here

# ========================================
# 数据库配置
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=spring_ai
DB_PASSWORD=123456

# ========================================
# Redis 配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# 服务器配置
# ========================================
SERVER_PORT=9090
